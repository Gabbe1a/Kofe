# PostgreSQL / VPS
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://kofe:change-me@db:5432/kofe_mama

# Yandex Object Storage (S3-compatible)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=kofe-mama-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
MEDIA_BASE_URL=https://storage.yandexcloud.net/kofe-mama-media

# Browser key for JavaScript API Yandex Maps in Staff Web. Restrict this key
# to the admin origin in the Yandex developer dashboard.
YANDEX_MAPS_API_KEY=

# Admin bootstrap (set once, then rotate the password)
ADMIN_BOOTSTRAP_EMAIL=admin@example.test
ADMIN_BOOTSTRAP_PASSWORD=change-me
STAFF_TOKEN_SECRET=replace-with-at-least-32-random-characters

# YooKassa test shop — never place production keys in source control.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Until HTTPS App Links exist, this may be a public web page with instructions
# to return to the app manually; it must not be an unverified IP deep link.
YOOKASSA_RETURN_URL=
